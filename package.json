{
  "name": "cadence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cadence — a CPU-scheduler-inspired human multitasking reminder with adaptive backoff polling.",
  "license": "MIT",
  "author": "caseclose",
  "homepage": "https://caseclose.github.io/cadence/",
  "repository": {
    "type": "git",
    "url": "https://github.com/caseclose/cadence.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:local": "VITE_BASE=/ npm run build",
    "preview": "vite preview",
    "preview:local": "vite preview --host",
    "start:local": "npm run build:local && npm run preview:local",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  }
}
