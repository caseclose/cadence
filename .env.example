# Copy to .env.local and adjust as needed.

# --- Supabase（可选）---
# 留空则纯本地模式（localStorage，无需登录）。
# 填入后可用户名登录、跨设备同步。两个值可安全放在浏览器端（靠 RLS 保护）。
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt

# --- 部署路径 ---
# 本地部署（根路径）：VITE_BASE=/
# GitHub Pages 项目站（/仓库名/）：VITE_BASE=/cadence/
# 开发模式 `npm run dev` 默认走 /，无需设置。
# VITE_BASE=/
